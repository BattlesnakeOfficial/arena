  "query": "\n        INSERT INTO saved_games (user_id, game_id, title)\n        VALUES ($1, $2, $3)\n        ON CONFLICT (user_id, game_id)\n        DO UPDATE SET title = EXCLUDED.title, updated_at = NOW()\n        RETURNING\n            saved_game_id,\n            user_id,\n            game_id,\n            title,\n            created_at,\n            updated_at\n        ",
