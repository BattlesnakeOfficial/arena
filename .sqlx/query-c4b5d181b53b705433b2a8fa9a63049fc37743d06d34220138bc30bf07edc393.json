  "query": "SELECT wrs.leaderboard_entry_id, wrs.score, wrs.wins, wrs.losses, wrs.games_played FROM win_rate_stats wrs JOIN leaderboard_entries le ON wrs.leaderboard_entry_id = le.leaderboard_entry_id WHERE le.leaderboard_id = $1 AND le.disabled_at IS NULL AND le.games_played >= $2 ORDER BY wrs.score DESC",
