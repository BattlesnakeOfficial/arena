  "query": "\n        SELECT\n            battlesnake_id,\n            user_id,\n            name,\n            url,\n            visibility as \"visibility: Visibility\",\n            color,\n            head,\n            tail,\n            created_at,\n            updated_at\n        FROM battlesnakes\n        WHERE visibility = 'public' AND name ILIKE '%' || $1 || '%'\n        ORDER BY name\n        LIMIT $2\n        ",
