  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            t.tag_id,\n            t.name,\n            t.category as \"category: TagCategory\",\n            t.created_at,\n            t.updated_at\n        FROM tags t\n        JOIN battlesnake_tags bt ON bt.tag_id = t.tag_id\n        WHERE bt.battlesnake_id = $1\n        ORDER BY t.category ASC, t.name ASC\n        ",
