  "db_name": "PostgreSQL",
  "query": "\n                SELECT\n                    battlesnake_id,\n                    user_id,\n                    name,\n                    url,\n                    visibility as \"visibility: _\",\n                    color,\n                    head,\n                    tail,\n                    created_at,\n                    updated_at\n                FROM battlesnakes\n                WHERE\n                    visibility = 'public'\n                    AND user_id != $1\n                    AND name ILIKE $2\n                ORDER BY name ASC\n                LIMIT 10\n                ",
