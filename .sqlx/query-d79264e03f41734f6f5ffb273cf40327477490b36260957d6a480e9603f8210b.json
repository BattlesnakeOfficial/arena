{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            sg.saved_game_id,\n            sg.game_id,\n            sg.title,\n            g.game_type,\n            g.board_size,\n            g.created_at AS game_created_at\n        FROM saved_games sg\n        JOIN games g ON g.game_id = sg.game_id\n        WHERE sg.user_id = $1\n        ORDER BY sg.created_at DESC\n        ",
